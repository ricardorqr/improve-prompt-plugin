#!/usr/bin/env bash
#
# Pre-push hook — runs Tier 1 static validation before every push.
# Blocks the push if scripts/test.sh fails.
#
# Enabled via a committed hooks dir:  git config core.hooksPath .githooks
# (see README → Testing). Bypass a single push with:  git push --no-verify

set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"

printf "pre-push: running Tier 1 validation (scripts/test.sh)…\n\n"
if ! "$ROOT/scripts/test.sh"; then
  printf "\npre-push: Tier 1 FAILED — push aborted. Use --no-verify to override.\n" >&2
  exit 1
fi
